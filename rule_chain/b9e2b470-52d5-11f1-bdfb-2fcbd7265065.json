      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "var totalSpaces = 100;\nvar occupiedSpaces = Number(msg.occupied_spaces);\nif (msg.occupied_spaces == null || isNaN(occupiedSpaces) || occupiedSpaces < 0) { occupiedSpaces = 0; }\nvar bookingStatus = msg.booking_status;\nif (bookingStatus == null) { bookingStatus = \"no_booking_request\"; }\nvar reservedSpaceId = \"none\";\nvar freeSpaces = totalSpaces - occupiedSpaces;\nif (bookingStatus == \"requested\") {\n  if (freeSpaces > 0) { occupiedSpaces = occupiedSpaces + 1; bookingStatus = \"confirmed\"; reservedSpaceId = \"P-\" + occupiedSpaces; }\n  else { bookingStatus = \"rejected\"; reservedSpaceId = \"none\"; }\n}\nfreeSpaces = totalSpaces - occupiedSpaces;\nvar occupancyRate = Math.round((occupiedSpaces / totalSpaces) * 100);\nvar basePrice = (msg.base_price_per_hour != null ? Number(msg.base_price_per_hour) : 2);\nvar demandLevel, currentPrice = basePrice;\nif (occupancyRate < 50) { demandLevel = \"LOW\"; }\nelse if (occupancyRate < 75) { demandLevel = \"MEDIUM\"; }\nelse if (occupancyRate < 90) { demandLevel = \"HIGH\"; }\nelse { demandLevel = \"CRITICAL\"; }\nvar bookingAvailable, displayStatus, displayMessage;\nif (freeSpaces <= 0) { bookingAvailable = false; displayStatus = \"FULL\"; displayMessage = \"Parkhaus voll \\u2013 keine Buchung m\\u00f6glich\"; }\nelse if (freeSpaces <= 10) { bookingAvailable = true; displayStatus = \"LIMITED\"; displayMessage = \"Nur noch \" + freeSpaces + \" Pl\\u00e4tze frei\"; }\nelse { bookingAvailable = true; displayStatus = \"AVAILABLE\"; displayMessage = freeSpaces + \" Pl\\u00e4tze frei \\u2013 Buchung m\\u00f6glich\"; }\nmsg.total_spaces = totalSpaces;\nmsg.occupied_spaces = occupiedSpaces;\nmsg.free_spaces = freeSpaces;\nmsg.occupancy_rate = occupancyRate;\nmsg.current_price_per_hour = currentPrice;\nmsg.booking_price = currentPrice;\nmsg.demand_level = demandLevel;\nmsg.booking_status = bookingStatus;\nmsg.reserved_space_id = reservedSpaceId;\nmsg.booking_available = bookingAvailable;\nmsg.display_status = displayStatus;\nmsg.display_message = displayMessage;\nreturn {msg: msg, metadata: metadata, msgType: msgType};",
        "tbelScript" : "return {msg: msg, metadata: metadata, msgType: msgType};"
