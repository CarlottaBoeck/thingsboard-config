      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "// Fixer Demonstrator-Wert: 100 Parkplätze\r\nvar totalSpaces = 100;\r\n\r\n// Eingehende belegte Plätze lesen\r\nvar occupiedSpaces = msg.occupied_spaces;\r\n\r\n// Falls nichts gesendet wurde\r\nif (occupiedSpaces == null) {\r\n    occupiedSpaces = 0;\r\n}\r\n\r\n// In Zahl umwandeln, falls ThingsBoard es als Text bekommt\r\noccupiedSpaces = Number(occupiedSpaces);\r\n\r\nif (isNaN(occupiedSpaces)) {\r\n    occupiedSpaces = 0;\r\n}\r\n\r\n// Grenzen absichern\r\nif (occupiedSpaces < 0) {\r\n    occupiedSpaces = 0;\r\n}\r\n\r\nif (occupiedSpaces > totalSpaces) {\r\n    occupiedSpaces = totalSpaces;\r\n}\r\n\r\n// Freie Plätze berechnen\r\nvar freeSpaces = totalSpaces - occupiedSpaces;\r\n\r\n// Auslastung berechnen\r\nvar occupancyRate = (occupiedSpaces / totalSpaces) * 100;\r\n\r\n// Basispreis\r\nvar basePrice = msg.base_price_per_hour;\r\n\r\nif (basePrice == null) {\r\n    basePrice = 2.0;\r\n}\r\n\r\nbasePrice = Number(basePrice);\r\n\r\nif (isNaN(basePrice)) {\r\n    basePrice = 2.0;\r\n}\r\n\r\n// Buchungsdauer\r\nvar duration = msg.requested_duration_hours;\r\n\r\nif (duration == null) {\r\n    duration = 1;\r\n}\r\n\r\nduration = Number(duration);\r\n\r\nif (isNaN(duration)) {\r\n    duration = 1;\r\n}\r\n\r\n// Preislogik\r\nvar priceFactor = 1.0;\r\nvar demandLevel = \"LOW\";\r\n\r\nif (occupancyRate < 50) {\r\n    priceFactor = 1.0;\r\n    demandLevel = \"LOW\";\r\n} else if (occupancyRate < 80) {\r\n    priceFactor = 1.2;\r\n    demandLevel = \"MEDIUM\";\r\n} else if (occupancyRate < 95) {\r\n    priceFactor = 1.5;\r\n    demandLevel = \"HIGH\";\r\n} else {\r\n    priceFactor = 2.0;\r\n    demandLevel = \"CRITICAL\";\r\n}\r\n\r\nvar currentPricePerHour = basePrice * priceFactor;\r\nvar bookingPrice = currentPricePerHour * duration;\r\n\r\n// Buchungslogik\r\nvar bookingStatus = msg.booking_status;\r\n\r\n// Falls booking_status fehlt, Status trotzdem sinnvoll setzen\r\nif (bookingStatus == null) {\r\n    bookingStatus = \"no_booking_request\";\r\n}\r\n\r\nvar reservedSpaceId = \"none\";\r\n\r\n// Nur bei echter Buchungsanfrage\r\nif (bookingStatus == \"requested\") {\r\n    if (freeSpaces > 0) {\r\n        bookingStatus = \"confirmed\";\r\n        reservedSpaceId = \"P-\" + (occupiedSpaces + 1);\r\n\r\n        occupiedSpaces = occupiedSpaces + 1;\r\n        freeSpaces = totalSpaces - occupiedSpaces;\r\n        occupancyRate = (occupiedSpaces / totalSpaces) * 100;\r\n    } else {\r\n        bookingStatus = \"rejected\";\r\n        reservedSpaceId = \"none\";\r\n    }\r\n}\r\n\r\n// Alles zurück in msg schreiben\r\nmsg.total_spaces = totalSpaces;\r\nmsg.occupied_spaces = occupiedSpaces;\r\nmsg.free_spaces = freeSpaces;\r\nmsg.occupancy_rate = Math.round(occupancyRate * 100) / 100;\r\nmsg.base_price_per_hour = basePrice;\r\nmsg.current_price_per_hour = Math.round(currentPricePerHour * 100) / 100;\r\nmsg.booking_price = Math.round(bookingPrice * 100) / 100;\r\nmsg.demand_level = demandLevel;\r\nmsg.booking_status = bookingStatus;\r\nmsg.reserved_space_id = reservedSpaceId;\r\n// Anzeige-Logik für Eingangsanzeige\r\nvar bookingAvailable = freeSpaces > 0;\r\nvar displayStatus = \"AVAILABLE\";\r\nvar displayMessage = freeSpaces + \" Plätze frei – Buchung möglich\";\r\n\r\nif (freeSpaces <= 0) {\r\n    bookingAvailable = false;\r\n    displayStatus = \"FULL\";\r\n    displayMessage = \"Parkhaus voll – keine Buchung möglich\";\r\n} else if (freeSpaces <= 10) {\r\n    displayStatus = \"LIMITED\";\r\n    displayMessage = \"Nur noch \" + freeSpaces + \" Plätze frei\";\r\n}\r\n\r\nmsg.booking_available = bookingAvailable;\r\nmsg.display_status = displayStatus;\r\nmsg.display_message = displayMessage;\r\n\r\n// Debug-Werte, damit ihr seht, ob die Logik läuft\r\nmsg.debug_script_executed = true;\r\nmsg.debug_free_spaces_before_booking = totalSpaces - Number(msg.occupied_spaces);\r\n\r\nreturn {msg: msg, metadata: metadata, msgType: msgType};",
        "tbelScript" : "return {msg: msg, metadata: metadata, msgType: msgType};"
      },
